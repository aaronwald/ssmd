# ssmd-data-ts: TypeScript data server for market data
FROM denoland/deno:bin-2.8.1 AS deno_bin
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates && rm -rf /var/lib/apt/lists/*
RUN groupadd -g 1000 deno && useradd -u 1000 -g deno -m deno

COPY --from=deno_bin /deno /usr/local/bin/deno

WORKDIR /app

# Cache deps into a shared DENO_DIR owned by the runtime user (uid 1000).
# Without this, `deno cache` runs as root and writes to /root/.cache/deno, which
# USER deno cannot read at runtime — so every pod cold-downloads all deps. On the
# CronJobs that means a slow download blows activeDeadlineSeconds (DeadlineExceeded),
# which is what killed the binance WS aggregate for 2026-06-30.
ENV DENO_DIR=/deno-dir

# Copy only necessary files for the server
COPY deno.json deno.lock ./
COPY src/server/ ./src/server/
COPY src/lib/ ./src/lib/
COPY src/config.ts ./src/config.ts
COPY src/cli/ ./src/cli/

# Cache dependencies (server + CLI for CronJob use) into DENO_DIR, then hand the
# populated cache to the runtime user so `deno run` reads it instead of downloading.
RUN deno cache src/server/main.ts src/cli/main.ts && chown -R deno:deno /deno-dir

# Pre-install DuckDB httpfs extension (DuckDB's internal downloader hangs in K8s).
# Version must match @duckdb/node-api in deno.json (currently 1.4.4).
RUN mkdir -p /app/duckdb_ext/v1.4.4/linux_amd64 && \
    curl -sL https://extensions.duckdb.org/v1.4.4/linux_amd64/httpfs.duckdb_extension.gz | \
    gunzip > /app/duckdb_ext/v1.4.4/linux_amd64/httpfs.duckdb_extension && \
    chmod -R 755 /app/duckdb_ext

# Create non-root user for security
USER deno

# Expose port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:8080/health || exit 1

# Run the server (--allow-ffi for DuckDB N-API, --allow-write=/tmp for DuckDB temp files)
CMD ["deno", "run", "--allow-net", "--allow-env", "--allow-read", "--allow-sys", "--allow-ffi", "--allow-write=/tmp", "src/server/main.ts"]
