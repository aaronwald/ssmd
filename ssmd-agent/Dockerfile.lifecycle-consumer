# ssmd-lifecycle-consumer: standalone daemon for market lifecycle events
# Separate from cli-ts to avoid DuckDB native dependency

FROM --platform=$BUILDPLATFORM denoland/deno:2.7.4 AS builder

ARG TARGETPLATFORM

WORKDIR /app

COPY deno.json deno.lock ./
COPY src/ ./src/

RUN deno cache src/cli/lifecycle-main.ts

RUN if [ "$TARGETPLATFORM" = "linux/arm64" ]; then \
      deno compile --target aarch64-unknown-linux-gnu \
        --allow-net --allow-env --allow-read --allow-write \
        --output /app/lifecycle-consumer src/cli/lifecycle-main.ts; \
    else \
      deno compile --target x86_64-unknown-linux-gnu \
        --allow-net --allow-env --allow-read --allow-write \
        --output /app/lifecycle-consumer src/cli/lifecycle-main.ts; \
    fi

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/lifecycle-consumer /usr/local/bin/lifecycle-consumer

RUN useradd -m deno
USER deno

ENTRYPOINT ["/usr/local/bin/lifecycle-consumer"]
