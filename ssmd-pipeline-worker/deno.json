{
  "tasks": {
    "start": "deno run --allow-net --allow-env --allow-read src/main.ts",
    "test": "deno test --allow-net --allow-env --allow-read src/",
    "check": "deno check src/main.ts"
  },
  "imports": {
    "postgres": "npm:postgres@^3.4.4",
    "drizzle-orm": "npm:drizzle-orm@^0.38.0",
    "drizzle-orm/": "npm:drizzle-orm@^0.38.0/",
    "nodemailer": "npm:nodemailer@^6",
    "cron-parser": "npm:cron-parser@^4.9.0"
  },
  "compilerOptions": {
    "strict": true
  }
}
